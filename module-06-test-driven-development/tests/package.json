{
  "name": "todo-app-test-suite",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "test": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:frontend && npm run test:security && npm run test:smoke && npm run test:regression",
    "test:unit": "jest --config ./jest.config.cjs --selectProjects unit",
    "test:integration": "jest --config ./jest.config.cjs --selectProjects integration",
    "test:api": "jest --config ./jest.config.cjs --selectProjects api",
    "test:frontend": "jest --config ./jest.config.cjs --selectProjects frontend",
    "test:security": "jest --config ./jest.config.cjs --selectProjects security",
    "test:regression": "jest --config ./jest.config.cjs --selectProjects regression",
    "test:smoke": "jest --config ./jest.config.cjs --selectProjects smoke",
    "test:acceptance": "playwright test --config ./playwright.config.ts tests/acceptance",
    "test:e2e": "playwright test --config ./playwright.config.ts tests/e2e",
    "test:playwright": "playwright test --config ./playwright.config.ts tests/e2e tests/acceptance tests/smoke",
    "test:performance:k6": "k6 run tests/performance/k6-script.js",
    "test:performance:artillery": "artillery run tests/performance/artillery.yml",
    "test:ci": "npm run test && npm run test:playwright"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@playwright/test": "^1.51.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^7.1.1"
  }
}
